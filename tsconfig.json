{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "types": ["@types/node"],
    "verbatimModuleSyntax": false,
    "isolatedModules": true
  },
  "include": ["api/**/*.ts", "scripts/**/*.ts"]
}
