  "description": "Backend API for the Scooter Rent Android app. Vercel + Neon Postgres.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "init-db": "node scripts/init-db.mjs",
