    "bcryptjs": "^2.4.3",
    "jose": "^5.6.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.30",
    "typescript": "^5.4.5",
    "vercel": "^34.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
