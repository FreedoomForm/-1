<?xml version="1.0" encoding="utf-8"?>
<!--
  Метаданные ОДНОГО виджета «ScooterRent Dashboard».

  КЛЮЧЕВЫЕ ОТЛИЧИЯ от старых 6 виджетов:
    • previewImage = @mipmap/ic_launcher — ИКОНКА ПРИЛОЖЕНИЯ
      В старых виджетах здесь был @drawable/preview_* — layer-list с
      <item android:width android:height>. Этот атрибут НЕ поддерживается
      в RemoteViews на Android 12+ (API 31+) — лаунчер не может отрендерить
      превью → виджет вообще не появляется в пикере, либо показывает
      "Failed to load widget" после размещения.

      Иконка приложения есть всегда, рендерится мгновенно, работает
      на всех версиях Android.

    • previewLayout = @layout/widget_dashboard (Android 12+ / API 31+)
      НОВЫЙ способ рендеринга превью — лаунчер напрямую инфлейтит
      сам layout виджета как превью. Надёжнее чем previewImage, потому
      что показывает реальный вид виджета. Атрибут игнорируется на
      API < 31, там используется previewImage.

    • updatePeriodMillis = 1800000 (30 минут) — системный минимум.
      В дополнение WidgetUpdater.updateAll() вызывается из приложения
      после любого изменения данных.

    • widgetCategory = home_screen — только домашний экран, не keyguard.
    • resizeMode = horizontal|vertical — пользователь может менять размер.
    • minHeight = 140dp — достаточно для 3 строк + шапки.
    • targetCellWidth/Height (API 31+) — точный размер в клетках лаунчера.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="140dp"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/widget_dashboard"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewImage="@mipmap/ic_launcher"
    android:previewLayout="@layout/widget_dashboard"
    android:targetCellWidth="4"
    android:targetCellHeight="3"
    android:description="@string/widget_dashboard_desc" />
