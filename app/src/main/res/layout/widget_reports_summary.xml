<?xml version="1.0" encoding="utf-8"?>
<!--
  Нативный виджет «Отчёты».
  Дизайн повторяет карточки в приложении:
    • левая цветная полоса-маркер (терракотовый градиент)
    • шапка: иконка-гистограмма в цветном кружке + заголовок «Otchetlar»
    • крупная цифра — sof foyda (зелёная) + подпись
    • мини-плитки 2×2: faol ijarachilar, qarzdorlar, bandlik, ROI
    • нижняя плашка-«чип» со сроком обновления
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg">

    <!-- Левая цветная полоса-маркер -->
    <View
        android:layout_width="6dp"
        android:layout_height="match_parent"
        android:background="@drawable/widget_accent_reports" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ── Шапка: иконка + заголовок + время обновления ──────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Цветной кружок-«плашка» с гистограммой (3 столбика) -->
            <FrameLayout
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/widget_accent_reports"
                android:layout_marginEnd="10dp">
                <View
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center"
                    android:background="@drawable/widget_chart_mini" />
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="OTCHETLAR"
                android:textColor="#251E12"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/widget_updated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#71624B"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- ── Крупная цифра: Sof foyda ──────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sof foyda"
                    android:textColor="#71624B"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_net_profit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#16A34A"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Мини-индикатор роста (стрелка вверх) -->
            <TextView
                android:id="@+id/widget_trend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▲"
                android:textColor="#16A34A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp" />
        </LinearLayout>

        <!-- ── Плитки 2×2: метрики ───────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <!-- Плитка 1: Faol ijarachilar -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#0D16A34A"
                android:padding="6dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Faol"
                    android:textColor="#71624B"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/widget_active_renters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#16A34A"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Плитка 2: Qarzdor -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#0DDC2626"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Qarzdor"
                    android:textColor="#71624B"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/widget_overdue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#DC2626"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Плитка 3: Bandlik -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#0DC14E24"
                android:padding="6dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bandlik"
                    android:textColor="#71624B"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/widget_occupancy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#C14E24"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Плитка 4: ROI -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#0DB8862B"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROI"
                    android:textColor="#71624B"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/widget_roi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#B8862B"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
