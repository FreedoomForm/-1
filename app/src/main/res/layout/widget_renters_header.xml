<?xml version="1.0" encoding="utf-8"?>
<!--
  Сводная плашка-«чип» над списком арендаторов в виджете.

  ВАЖНО: в старой версии внизу был <View android:layout_height="1dp"
  android:background="#24251E12"> — ГОРИЗОНТАЛЬНЫЙ РАЗДЕЛИТЕЛЬ.
  Именно такие <View>-разделители плохо рендерятся в RemoteViews на
  некоторых лаунчерах (MIUI, One UI). УБРАНО — вместо этого даём всей
  плашке полупрозрачный фон-чип.

  Маленькие цветные точки-индикаторы — это ImageView с shape drawable,
  не <View>. ImageView безопасен в RemoteViews на всех API 24+.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp"
    android:layout_marginBottom="4dp"
    android:background="#0D251E12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/widget_dot_neutral"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jami: "
            android:textColor="#71624B"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/header_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#251E12"
            android:textSize="10sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/widget_dot_ok"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Faol: "
            android:textColor="#71624B"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/header_active"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#16A34A"
            android:textSize="10sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/widget_dot_overdue"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Qarzdor: "
            android:textColor="#71624B"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/header_overdue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#DC2626"
            android:textSize="10sp"
            android:textStyle="bold" />

        <!-- Совместимость со старым кодом, ожидавшим header_summary -->
        <TextView
            android:id="@+id/header_summary"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text=""
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
