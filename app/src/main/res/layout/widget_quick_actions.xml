<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tezkor amallar"
        android:textColor="#251E12"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button
            android:id="@+id/btn_create_renter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ Ijarachi"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C14E24"
            android:textSize="11sp"
            android:padding="6dp"
            android:minHeight="36dp" />

        <View android:layout_width="6dp" android:layout_height="match_parent" />

        <Button
            android:id="@+id/btn_create_scooter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ Skuter"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C14E24"
            android:textSize="11sp"
            android:padding="6dp"
            android:minHeight="36dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_create_contract"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ Kontrakt"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B8862B"
            android:textSize="11sp"
            android:padding="6dp"
            android:minHeight="36dp" />

        <View android:layout_width="6dp" android:layout_height="match_parent" />

        <Button
            android:id="@+id/btn_create_transaction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ Tranzaksiya"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B8862B"
            android:textSize="11sp"
            android:padding="6dp"
            android:minHeight="36dp" />
    </LinearLayout>
</LinearLayout>
