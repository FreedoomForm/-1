<?xml version="1.0" encoding="utf-8"?>
<!--
  Нативный виджет «Список скутеров».
  Слева — бирюзовая полоса-маркер. Шапка с кружком-иконкой и счётчиком.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg">

    <View
        android:layout_width="6dp"
        android:layout_height="match_parent"
        android:background="@drawable/widget_accent_scooters" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <FrameLayout
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/widget_accent_scooters"
                android:layout_marginEnd="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🛴"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SKUTERLAR"
                android:textColor="#251E12"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/widget_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#71624B"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ListView
            android:id="@+id/widget_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="#24251E12"
            android:dividerHeight="1dp" />

        <LinearLayout
            android:id="@+id/widget_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛴"
                android:textSize="32sp"
                android:alpha="0.4" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hozircha skuterlar yo'q"
                android:textColor="#71624B"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
