<?xml version="1.0" encoding="utf-8"?>
<!--
  Превью нативного виджета «Отчёты» для окна выбора виджетов.
  Слева — иконка-гистограмма на терракотовом градиенте, справа — метки
  ключевых метрик (fo'ida / ROI / bandlik). Так пользователь отличит
  этот виджет от остальных в списке.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:width="240dp" android:height="140dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFCF3" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#24251E12" />
        </shape>
    </item>
    <!-- Левый цветной блок-«плашка» с иконкой-графиком -->
    <item android:left="8dp" android:top="8dp" android:right="160dp" android:bottom="8dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#C14E24"
                android:endColor="#B8862B"
                android:angle="45" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Иконка-гистограмма (3 столбика разной высоты) -->
    <item android:left="22dp" android:top="50dp" android:width="14dp" android:height="40dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    <item android:left="40dp" android:top="35dp" android:width="14dp" android:height="55dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    <item android:left="58dp" android:top="22dp" android:width="14dp" android:height="68dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    <!-- Текстовые метрики справа -->
    <item android:left="92dp" android:top="14dp" android:right="10dp" android:height="22dp">
        <shape android:shape="rectangle">
            <solid android:color="#F6EDD6" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item android:left="92dp" android:top="44dp" android:right="10dp" android:height="22dp">
        <shape android:shape="rectangle">
            <solid android:color="#16A34A" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item android:left="92dp" android:top="74dp" android:right="60dp" android:height="22dp">
        <shape android:shape="rectangle">
            <solid android:color="#C14E24" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item android:left="92dp" android:top="104dp" android:right="40dp" android:height="22dp">
        <shape android:shape="rectangle">
            <solid android:color="#B8862B" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</layer-list>
