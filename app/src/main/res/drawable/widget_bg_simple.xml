<?xml version="1.0" encoding="utf-8"?>
<!--
  Фон для виджета «ScooterRent Dashboard».
  Намеренно ПРОСТОЙ: solid color + corners + лёгкая обводка.
  Никаких gradient, layer-list, ripple — это всё ломает RemoteViews
  на некоторых лаунчерах/версиях Android.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFCF3" />
    <corners android:radius="16dp" />
    <stroke android:width="1dp" android:color="#24251E12" />
</shape>
