<?xml version="1.0" encoding="utf-8"?>
<!--
  Общий фон для всех виджетов — простая форма (solid color + corners + stroke).
  Используется во всех 6 виджетах как корневой background.

  БЕЗОПАСНО для RemoteViews на всех API 24+: только <solid>, <corners>, <stroke>.
  Никаких <gradient>, <layer-list>, <inset>, <ripple>.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFCF3" />
    <corners android:radius="16dp" />
    <stroke android:width="1dp" android:color="#24251E12" />
</shape>
