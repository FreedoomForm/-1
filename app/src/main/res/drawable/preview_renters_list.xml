<?xml version="1.0" encoding="utf-8"?>
<!--
  Превью виджета «Список арендаторов» — три строки с именем + балансом +
  цветным индикатором статуса (зелёный/красный), под каждой строкой —
  четыре мини-кнопки To'lov/Uzish/SMS/O'chir.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:width="240dp" android:height="180dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFCF3" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#24251E12" />
        </shape>
    </item>
    <!-- Шапка с зелёной полосой слева + название -->
    <item android:left="0dp" android:top="0dp" android:width="6dp" android:height="180dp">
        <shape android:shape="rectangle">
            <solid android:color="#16A34A" />
        </shape>
    </item>
    <item android:left="14dp" android:top="10dp" android:right="100dp" android:height="14dp">
        <shape android:shape="rectangle">
            <solid android:color="#251E12" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <!-- Строка 1: имя + баланс (зелёный кружок-индикатор) -->
    <item android:left="14dp" android:top="32dp" android:width="10dp" android:height="10dp">
        <shape android:shape="oval">
            <solid android:color="#16A34A" />
        </shape>
    </item>
    <item android:left="30dp" android:top="30dp" android:right="80dp" android:height="14dp">
        <shape android:shape="rectangle">
            <solid android:color="#71624B" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <item android:left="180dp" android:top="30dp" android:right="14dp" android:height="14dp">
        <shape android:shape="rectangle">
            <solid android:color="#16A34A" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- Кнопки строки 1 -->
    <item android:left="14dp" android:top="50dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#16A34A" /><corners android:radius="3dp" /></shape>
    </item>
    <item android:left="68dp" android:top="50dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#DC2626" /><corners android:radius="3dp" /></shape>
    </item>
    <item android:left="122dp" android:top="50dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#C14E24" /><corners android:radius="3dp" /></shape>
    </item>
    <item android:left="176dp" android:top="50dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#71624B" /><corners android:radius="3dp" /></shape>
    </item>

    <!-- Строка 2 (красный индикатор) -->
    <item android:left="14dp" android:top="82dp" android:width="10dp" android:height="10dp">
        <shape android:shape="oval"><solid android:color="#DC2626" /></shape>
    </item>
    <item android:left="30dp" android:top="80dp" android:right="80dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#71624B" /><corners android:radius="2dp" /></shape>
    </item>
    <item android:left="180dp" android:top="80dp" android:right="14dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#DC2626" /><corners android:radius="2dp" /></shape>
    </item>
    <item android:left="14dp" android:top="100dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#16A34A" /><corners android:radius="3dp" /></shape>
    </item>
    <item android:left="68dp" android:top="100dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#DC2626" /><corners android:radius="3dp" /></shape>
    </item>
    <item android:left="122dp" android:top="100dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#C14E24" /><corners android:radius="3dp" /></shape>
    </item>
    <item android:left="176dp" android:top="100dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#71624B" /><corners android:radius="3dp" /></shape>
    </item>

    <!-- Строка 3 (зелёный индикатор) -->
    <item android:left="14dp" android:top="132dp" android:width="10dp" android:height="10dp">
        <shape android:shape="oval"><solid android:color="#16A34A" /></shape>
    </item>
    <item android:left="30dp" android:top="130dp" android:right="80dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#71624B" /><corners android:radius="2dp" /></shape>
    </item>
    <item android:left="180dp" android:top="130dp" android:right="14dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#16A34A" /><corners android:radius="2dp" /></shape>
    </item>
    <item android:left="14dp" android:top="150dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#16A34A" /><corners android:radius="3dp" /></shape>
    </item>
    <item android:left="68dp" android:top="150dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#DC2626" /><corners android:radius="3dp" /></shape>
    </item>
    <item android:left="122dp" android:top="150dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#C14E24" /><corners android:radius="3dp" /></shape>
    </item>
    <item android:left="176dp" android:top="150dp" android:width="48dp" android:height="14dp">
        <shape android:shape="rectangle"><solid android:color="#71624B" /><corners android:radius="3dp" /></shape>
    </item>
</layer-list>
