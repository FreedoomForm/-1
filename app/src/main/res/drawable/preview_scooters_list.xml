<?xml version="1.0" encoding="utf-8"?>
<!--
  Превью виджета «Список скутеров» — бирюзовая полоса слева, имя + статус
  каждой строки + красная кнопка «O'chir» справа.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:width="240dp" android:height="160dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFCF3" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#24251E12" />
        </shape>
    </item>
    <!-- Бирюзовая полоса слева -->
    <item android:left="0dp" android:top="0dp" android:width="6dp" android:height="160dp">
