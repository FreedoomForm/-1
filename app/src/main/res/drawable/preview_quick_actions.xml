<?xml version="1.0" encoding="utf-8"?>
<!--
  Превью виджета «Быстрые действия» — 4 кнопки создания на тёплом фоне.
  Сетка 2×2 из цветных квадратов имитирует реальный вид виджета.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:width="240dp" android:height="120dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFCF3" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#24251E12" />
        </shape>
    </item>
    <!-- Заголовок -->
    <item android:left="10dp" android:top="8dp" android:right="80dp" android:height="14dp">
        <shape android:shape="rectangle">
            <solid android:color="#251E12" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- Кнопка 1: + Ijarachi (терракота) -->
    <item android:left="10dp" android:top="30dp" android:width="105dp" android:height="34dp">
        <shape android:shape="rectangle">
            <solid android:color="#C14E24" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Кнопка 2: + Skuter (терракота) -->
    <item android:left="125dp" android:top="30dp" android:width="105dp" android:height="34dp">
        <shape android:shape="rectangle">
            <solid android:color="#C14E24" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Кнопка 3: + Kontrakt (золото) -->
    <item android:left="10dp" android:top="72dp" android:width="105dp" android:height="34dp">
        <shape android:shape="rectangle">
            <solid android:color="#B8862B" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Кнопка 4: + Tranzaksiya (золото) -->
    <item android:left="125dp" android:top="72dp" android:width="105dp" android:height="34dp">
        <shape android:shape="rectangle">
            <solid android:color="#B8862B" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
