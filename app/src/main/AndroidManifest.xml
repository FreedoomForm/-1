<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />
    <!-- Для установки обновлений из приложения (Android 8+) -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Для сохранения PDF-договоров в общую папку Documents (Android 9 и ниже) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MyApplication">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".worker.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.ACTION_PAYMENT_RECEIVED" />
                <action android:name="com.example.ACTION_TERMINATE_CONTRACT" />
            </intent-filter>
        </receiver>

        <!-- FileProvider для генерации и расшаривания PDF-договоров -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- НАТИВНЫЕ ВИДЖЕТЫ ГЛАВНОГО ЭКРАНА ANDROID                         -->
        <!-- ════════════════════════════════════════════════════════════════ -->

        <!-- Виджет «Отчёты» — сводка ключевых метрик -->
        <receiver
            android:name=".widget.ReportsSummaryWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_reports_summary" />
        </receiver>

        <!-- Виджет «Быстрые действия» — 4 кнопки создания -->
        <receiver
            android:name=".widget.QuickActionsWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_quick_actions" />
        </receiver>

        <!-- Виджет «Список арендаторов» с кнопками To'lov/Uzish/SMS/O'chir -->
        <receiver
            android:name=".widget.RentersListWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.example.widget.ACTION_PAY" />
                <action android:name="com.example.widget.ACTION_TERMINATE" />
                <action android:name="com.example.widget.ACTION_SMS" />
                <action android:name="com.example.widget.ACTION_DELETE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_renters_list" />
        </receiver>
        <service
            android:name=".widget.RentersListRemoteViewsService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- Виджет «Список скутеров» с кнопкой удаления -->
        <receiver
            android:name=".widget.ScootersListWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.example.widget.ACTION_DELETE_SCOOTER" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_scooters_list" />
        </receiver>
        <service
            android:name=".widget.ScootersListRemoteViewsService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- Виджет «Список контрактов» с кнопкой удаления -->
        <receiver
            android:name=".widget.ContractsListWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.example.widget.ACTION_DELETE_CONTRACT" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_contracts_list" />
        </receiver>
        <service
            android:name=".widget.ContractsListRemoteViewsService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- Виджет «Список транзакций» с кнопкой удаления -->
        <receiver
            android:name=".widget.TransactionsListWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.example.widget.ACTION_DELETE_TX" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/appwidget_transactions_list" />
        </receiver>
        <service
            android:name=".widget.TransactionsListRemoteViewsService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

    </application>

</manifest>
